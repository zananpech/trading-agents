# Langfuse Docker Compose — Infrastructure Secrets
# Copy this file to docker-compose.env and fill in values.
# This file is gitignored — never commit secrets.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=langfuse

# ── Langfuse App ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:changeme_postgres_password@postgres:5432/langfuse

# Generate all three with: uv run python -c "import secrets; print(secrets.token_hex(32))"
# Or with openssl:          openssl rand -hex 32
# Each must be exactly 64 hex characters (256 bits)
NEXTAUTH_SECRET=<replace-with-64-char-hex-from-openssl-rand-hex-32>
SALT=<replace-with-64-char-hex-from-openssl-rand-hex-32>
ENCRYPTION_KEY=<replace-with-64-char-hex-from-openssl-rand-hex-32>

NEXTAUTH_URL=http://localhost:3000
LANGFUSE_INIT_ORG_ID=my-org
LANGFUSE_INIT_ORG_NAME=Trading Agents
LANGFUSE_INIT_PROJECT_ID=trading-agents-project
LANGFUSE_INIT_PROJECT_NAME=trading-agents
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-trading-agents
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-trading-agents
LANGFUSE_INIT_USER_EMAIL=admin@local.dev
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=changeme_admin_password

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=langfuse
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=changeme_clickhouse_password
# CLICKHOUSE_URL uses HTTP port 8123 (required by Langfuse v3 — different from TCP port 9000)
CLICKHOUSE_URL=http://clickhouse:changeme_clickhouse_password@clickhouse:8123
CLICKHOUSE_MIGRATION_URL=clickhouse://clickhouse:changeme_clickhouse_password@clickhouse:9000/langfuse

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Minio (S3-compatible storage) ─────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecret
LANGFUSE_S3_EVENT_UPLOAD_ENABLED=true
LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=miniosecret
LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=http://minio:9000
LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=true
LANGFUSE_S3_EVENT_UPLOAD_REGION=us-east-1

LANGFUSE_S3_MEDIA_UPLOAD_ENABLED=true
LANGFUSE_S3_MEDIA_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=miniosecret
LANGFUSE_S3_MEDIA_UPLOAD_ENDPOINT=http://minio:9000
LANGFUSE_S3_MEDIA_UPLOAD_FORCE_PATH_STYLE=true
LANGFUSE_S3_MEDIA_UPLOAD_REGION=us-east-1
